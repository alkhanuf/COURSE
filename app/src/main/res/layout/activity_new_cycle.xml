<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:padding="15dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Созлание тренировочного цикла"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/white_text"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Выберите программу:"
            android:textSize="14sp"
            android:textColor="@color/grey_text"
            android:layout_marginBottom="8dp"/>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/surface_dark"
            android:padding="4dp"
            android:layout_marginBottom="24dp">

            <Spinner
                android:id="@+id/spinnerPrograms"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp" />
        </FrameLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Фазы периодизации:"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/white_text"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:id="@+id/phasesList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <Button
            android:id="@+id/btnAddPhase"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+ Добавить фазу"
            style="?android:attr/borderlessButtonStyle"
            android:textColor="@color/purple_primary"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="32dp"/>

        <Button
            android:id="@+id/btnGenerateCycle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Рассчитать и запустить цикл"
            android:textColor="@color/white_text"
            android:textSize="16sp"
            android:textStyle="bold"
            android:padding="14dp"/>

    </LinearLayout>
</ScrollView>